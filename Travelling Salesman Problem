#include <iostream>
#include <climits>
using namespace std;

#define N 4  // Number of cities

int graph[N][N] = {
    {0, 10, 15, 20},
    {10, 0, 35, 25},
    {15, 35, 0, 30},
    {20, 25, 30, 0}
};

bool visited[N];
int minCost = INT_MAX;

// TSP function
void tsp(int currPos, int count, int cost, int start) {
    if (count == N && graph[currPos][start]) {
        minCost = min(minCost, cost + graph[currPos][start]);
        return;
    }

    for (int i = 0; i < N; i++) {
        if (!visited[i] && graph[currPos][i]) {
            visited[i] = true;
            tsp(i, count + 1, cost + graph[currPos][i], start);
            visited[i] = false; // backtrack
        }
    }
}

int main() {
    for (int i = 0; i < N; i++)
        visited[i] = false;

    visited[0] = true; // start from city 0

    tsp(0, 1, 0, 0);

    cout << "Minimum Travelling Cost: " << minCost << endl;

    return 0;
}
